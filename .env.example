# Kopieer dit bestand naar .env en vul jouw waarden in

# Anthropic (verplicht)
ANTHROPIC_API_KEY=sk-ant-api03-...

# WooCommerce (laat leeg om demo-assortiment te gebruiken)
WC_URL=https://jouw-wijnshop.nl
WC_KEY=ck_...
WC_SECRET=cs_...

# Vivino (optioneel)
VIVINO_CLIENT_ID=jouw_client_id
VIVINO_CLIENT_SECRET=jouw_client_secret
VIVINO_USERNAME=jouw_vivino_gebruikersnaam
VIVINO_PASSWORD=jouw_vivino_wachtwoord

# Optioneel
PORT=3000
ALLOWED_ORIGIN=https://jouw-wijnshop.nl
